{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/v4v-io/metaboost-registry/main/schema/app-record.schema.json",
  "title": "Metaboost Registry App Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "app_id",
    "display_name",
    "owner",
    "status",
    "signing_keys",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "app_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "email"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "revoked"
      ]
    },
    "signing_keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kty",
          "crv",
          "alg",
          "x",
          "status"
        ],
        "properties": {
          "kid": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "kty": {
            "type": "string",
            "const": "OKP"
          },
          "crv": {
            "type": "string",
            "const": "Ed25519"
          },
          "alg": {
            "type": "string",
            "const": "EdDSA"
          },
          "x": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{43,64}$"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "retired",
              "revoked"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
